# ZRExtrack — Template des variables d'environnement
# Copiez ce fichier en `.env.local` et remplissez avec vos vraies valeurs.
# .env.local est dans .gitignore — il ne sera jamais commité.
#
# Sur Vercel : ajoutez ces variables dans Settings → Environment Variables.

# ─── Supabase (obligatoire) ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# CRITIQUE — clé admin, jamais exposée côté client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── IA — fallback global (BYOK désactive ces fallbacks pour les users) ─────
# Pour le bot WhatsApp / Messenger principal : chaque user fournit la sienne
# via /parametres/api-keys. Ces fallbacks sont utilisés seulement par les
# routes admin (chatbot drawer, bot-settings/test, diagnostic).
GEMINI_API_KEY=
GROQ_API_KEY=
# Claude/Anthropic retiré de la plateforme — laisser vide.
# ANTHROPIC_API_KEY=

# ─── WhatsApp Evolution API (gateway partagé de la plateforme) ────────────────
# Serveur Evolution utilisé par TOUS les clients pour connecter leur numéro
# WhatsApp (la connexion est gérée par la plateforme, pas en BYOK).
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# ─── ZRExpress (per-user via /sync — pas besoin ici) ──────────────────────────
# Les credentials ZRExpress sont stockés par user dans Supabase
# (table user_sync_settings). Aucune variable d'environnement nécessaire.
# Optionnel — override de l'endpoint swap :
# ZREXPRESS_SWAP_ENDPOINT=

# ─── Public — visibles côté client, OK d'être dans le repo ──────────────────
NEXT_PUBLIC_SITE_URL=https://zrextrack.vercel.app
NEXT_PUBLIC_APP_URL=https://zrextrack.vercel.app
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Optionnel — autres intégrations ──────────────────────────────────────────
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GOOGLE_SHEETS_WEBHOOK_URL=
